# 行者学社 V2.7 后端环境变量（模板）
# 复制为 .env 后填入真实值，不要提交 .env

# ── Environment ──
NODE_ENV=development

# ── Server ──
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ── Database (production uses MySQL, development uses SQLite) ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=xingzhe
DB_PASSWORD=
DB_DATABASE=xingzhe
# 生产环境默认 false。V2.7 首次空库部署可临时设为 true 建表，建完后改回 false 重启。
DB_SYNCHRONIZE=false

# ── Uploads ──
# 上传文件保存目录（绝对路径）
UPLOAD_DIR=
# 上传文件公开访问前缀
PUBLIC_UPLOAD_BASE_URL=

# ── WeChat Mini Program ──
WECHAT_APPID=
WECHAT_SECRET=
# 登录模式: mock / real
WECHAT_LOGIN_MODE=mock

# ── JWT ──
JWT_SECRET=change-me-in-production
