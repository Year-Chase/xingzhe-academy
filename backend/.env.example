# 行者学社 V2.7 后端环境变量（模板）
# 复制为 .env 后填入真实值，不要提交 .env

# ── Environment ──
NODE_ENV=development

# ── Server ──
PORT=3000
CORS_ORIGIN=http://localhost:5173,http://localhost:4173

# ── Database (production uses MySQL, development uses SQLite) ──
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=xingzhe
DB_PASSWORD=
DB_DATABASE=xingzhe
# 生产环境默认 false。V2.7 首次空库部署可临时设为 true 建表，建完后改回 false 重启。
DB_SYNCHRONIZE=false

# ── Uploads ──
# 上传文件保存目录（绝对路径）
UPLOAD_DIR=
# 上传文件公开访问前缀
PUBLIC_UPLOAD_BASE_URL=

# ── WeChat Mini Program ──
WECHAT_APPID=
WECHAT_SECRET=
# 登录模式: mock / real
WECHAT_LOGIN_MODE=mock
# 小程序用户态 JWT。生产环境必须配置至少 32 字符随机密钥，不得与 Admin token 密钥共用。
MINIAPP_JWT_SECRET=change-me-to-a-random-string-at-least-32-chars-long
# 小程序 token 有效期，支持 s/m/h/d，例如 30d。
MINIAPP_JWT_EXPIRES_IN=30d

# ── Demo Seed ──
# 仅本地开发可设为 true，会在空库中创建 5 条演示活动。生产环境必须保持 false。
ENABLE_DEMO_SEED=false

# ── Admin Authentication ──
# 服务端管理员登录凭证，仅在服务器 .env 中配置真实值
ADMIN_USERNAME=your-admin-username
ADMIN_PASSWORD=your-strong-password
# HMAC-SHA256 token 签名密钥（至少 64 字符随机字符串）
ADMIN_TOKEN_SECRET=change-me-to-a-random-string-at-least-64-chars-long
# token 过期秒数（默认 86400 = 24 小时）
ADMIN_TOKEN_EXPIRES_SECONDS=86400
