@charset "UTF-8";
page {
  background: #F7F2E8;
  font-family: "PingFang SC", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
  font-size: 30rpx;
  color: #18231E;
  line-height: 1.6;
}
/* P0 location lock — blocks entire app until location granted */
.lock-overlay {
  position: fixed;
  inset: 0;
  z-index: 10000;
  background: rgba(24, 35, 30, 0.62);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
}
.lock-card {
  width: 100%;
  max-width: 600rpx;
  background: #FBFAF6;
  border-radius: 40rpx;
  padding: 56rpx 40rpx 40rpx;
  text-align: center;
}
.lock-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 8rpx;
}
.lock-sub {
  font-size: 28rpx;
  color: #7A8178;
  display: block;
  margin-bottom: 48rpx;
}
.lock-body {
  text-align: left;
  margin-bottom: 40rpx;
}
.lock-text {
  font-size: 28rpx;
  color: #7A8178;
  line-height: 1.7;
  display: block;
  margin-bottom: 16rpx;
}
.lock-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 999rpx;
  background: #18231E;
  color: #FBFAF6;
  border: none;
}
.lock-btn::after {
  border: none;
}
