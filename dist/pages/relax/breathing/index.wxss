@charset "UTF-8";
.breath-page {
  min-height: 100vh;
  background: #1a1a2e;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx 60rpx;
}
/* 新手引导 */
.breath-guide {
  font-size: 28rpx;
  color: #86868B;
  text-align: center;
  margin-bottom: 60rpx;
  display: block;
}
.breath-circle-wrap {
  width: 220rpx;
  height: 220rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48rpx;
}
/* 19s 呼吸周期：4s放大 → 7s维持 → 8s缩小 */
@keyframes breathing478 {
  0% {
    transform: scale(1);
    background: radial-gradient(circle, rgba(46, 204, 113, 0.3), rgba(46, 204, 113, 0.05) 70%);
  }
  21.05% {
    transform: scale(1.6);
    background: radial-gradient(circle, rgba(46, 204, 113, 0.7), rgba(46, 204, 113, 0.2) 70%);
  }
  57.89% {
    transform: scale(1.6);
    background: radial-gradient(circle, rgba(52, 152, 219, 0.7), rgba(52, 152, 219, 0.15) 70%);
  }
  100% {
    transform: scale(1);
    background: radial-gradient(circle, rgba(46, 204, 113, 0.3), rgba(46, 204, 113, 0.05) 70%);
  }
}
.breath-circle {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  box-shadow: 0 0 50rpx rgba(46, 204, 113, 0.3), 0 0 100rpx rgba(46, 204, 113, 0.1);
  animation: breathing478 19s infinite linear;
}
.breath-circle.paused {
  animation-play-state: paused;
}
/* 巨幕文案 */
.breath-phase {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
}
.breath-countdown {
  font-size: 72rpx;
  font-weight: 300;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}
.breath-info {
  display: flex;
  gap: 32rpx;
  margin-bottom: 48rpx;
}
.breath-rounds {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}
.breath-elapsed {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.3);
}
.breath-btns {
  display: flex;
  gap: 32rpx;
}
.breath-btn {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  padding: 14rpx 36rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
}
/* 完成页 */
.breath-done {
  text-align: center;
}
.done-icon {
  font-size: 72rpx;
  display: block;
  margin-bottom: 20rpx;
}
.done-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
  display: block;
  margin-bottom: 10rpx;
}
.done-time {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
  display: block;
  margin-bottom: 40rpx;
}
.done-btn {
  font-size: 30rpx;
  color: rgba(46, 204, 113, 0.85);
  padding: 16rpx 48rpx;
  border: 1rpx solid rgba(46, 204, 113, 0.3);
  border-radius: 28rpx;
}
