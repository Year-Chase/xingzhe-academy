.page {
  padding: 32rpx 28rpx 60rpx;
  min-height: 100vh;
  background: #f7f8fa;
}

.page-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
  margin-bottom: 24rpx;
}

.loading {
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 200rpx;
  display: block;
}

.empty {
  text-align: center;
  font-size: 26rpx;
  color: #999;
  margin-top: 100rpx;
  display: block;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 14rpx;
}

.card.archived {
  opacity: 0.4;
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.code {
  font-size: 24rpx;
  font-weight: 600;
  color: #1989fa;
}

.type {
  font-size: 22rpx;
  color: #666;
  background: #f0f0f0;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.status {
  font-size: 22rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.status-ENABLED {
  background: #f0faf4;
  color: #07c160;
}

.status-DISABLED {
  background: #fffbe6;
  color: #ff976a;
}

.status-ARCHIVED {
  background: #f0f0f0;
  color: #999;
}

.title-text {
  font-size: 28rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.meta {
  font-size: 24rpx;
  color: #999;
}

.actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.btn-sm {
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  background: #1989fa;
  color: #fff;
  border-radius: 8rpx;
  border: none;
  height: auto;
  line-height: 1.5;
}

.btn-danger {
  background: #ee0a24;
}
