.login-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F2E8 0%, #FBFAF6 45%, #EEF3ED 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 32rpx;
}

.login-card {
  width: 100%;
  max-width: 600rpx;
  background: #FBFAF6;
  border-radius: 40rpx;
  padding: 64rpx 40rpx 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 40rpx rgba(24, 35, 30, 0.06);
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}

.login-title {
  font-size: 48rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.login-subtitle {
  font-size: 30rpx;
  color: #7A8178;
  display: block;
  margin-bottom: 56rpx;
}

.login-phone-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 999rpx;
  background: #18231E;
  color: #FBFAF6;
  border: none;
}

.login-phone-btn::after {
  border: none;
}

.login-guest-link {
  margin-top: 36rpx;
  padding: 16rpx 0;
}

.guest-link-text {
  font-size: 28rpx;
  color: #A6AAA2;
}
