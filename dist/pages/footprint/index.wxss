@charset "UTF-8";
.wp-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F2E8 0%, #FBFAF6 35%, #EEF3ED 100%);
  padding: 48rpx 32rpx 120rpx;
}
.wp-loading {
  text-align: center;
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 240rpx;
  display: block;
}
/* ===== Module 1: Identity ===== */
.wp-identity {
  background: linear-gradient(135deg, #18231E 0%, #2E3B34 40%, #3F6B4F 100%);
  border-radius: 40rpx;
  padding: 48rpx 32rpx 40rpx;
  margin-bottom: 48rpx;
  color: #FBFAF6;
  position: relative;
  overflow: hidden;
}
.wp-id-name {
  font-size: 52rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
  letter-spacing: 1rpx;
  color: #FBFAF6;
}
.wp-id-joined {
  font-size: 26rpx;
  color: rgba(251, 250, 246, 0.5);
  display: block;
  margin-bottom: 36rpx;
}
.wp-id-stats {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}
.wp-stat-item {
  background: rgba(251, 250, 246, 0.08);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  text-align: center;
  flex: 1;
  min-width: 120rpx;
  backdrop-filter: blur(8rpx);
}
.wp-stat-num {
  font-size: 52rpx;
  font-weight: 500;
  display: block;
  color: #FBFAF6;
  line-height: 1;
}
.wp-stat-label {
  font-size: 24rpx;
  color: rgba(251, 250, 246, 0.45);
  display: block;
  margin-top: 8rpx;
  letter-spacing: 2rpx;
}
.wp-speaker-badge {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}
.wp-badge-text {
  background: rgba(217, 199, 163, 0.18);
  color: #D9C7A3;
  font-size: 24rpx;
  font-weight: 500;
  padding: 8rpx 28rpx;
  border-radius: 999rpx;
  letter-spacing: 4rpx;
}
/* ===== Section header ===== */
.wp-section {
  margin-bottom: 48rpx;
}
.wp-section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 24rpx;
  letter-spacing: 1rpx;
}
/* ===== Module 2: Journey Timeline ===== */
.wp-timeline {
  position: relative;
  padding-left: 40rpx;
}
.wp-tl-line {
  position: absolute;
  left: 11rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 2rpx;
  background: linear-gradient(180deg, #D9C7A3 0%, rgba(217, 199, 163, 0.3) 60%, rgba(217, 199, 163, 0) 100%);
}
.wp-tl-node {
  position: relative;
  margin-bottom: 48rpx;
}
.wp-tl-dot {
  position: absolute;
  left: -33rpx;
  top: 24rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #3F6B4F;
  box-shadow: 0 0 0 6rpx rgba(63, 107, 79, 0.12);
}
.wp-tl-card {
  background: #FBFAF6;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 16rpx rgba(24, 35, 30, 0.03);
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}
.wp-tl-label {
  font-size: 24rpx;
  color: #78906F;
  background: #EEF3ED;
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  display: inline-block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}
.wp-tl-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 8rpx;
  line-height: 1.4;
}
.wp-tl-meta {
  font-size: 26rpx;
  color: #7A8178;
  display: block;
  margin-bottom: 12rpx;
}
.wp-tl-cert {
  font-size: 26rpx;
  color: #D9C7A3;
  letter-spacing: 1rpx;
}
.wp-show-more {
  text-align: center;
  padding: 16rpx 0;
  margin-top: 12rpx;
}
.wp-show-more-text {
  font-size: 28rpx;
  color: #3F6B4F;
}
/* ===== Empty state ===== */
.wp-empty-state {
  text-align: center;
  padding: 80rpx 32rpx;
}
.wp-empty-text {
  font-size: 30rpx;
  color: #7A8178;
  display: block;
}
.wp-empty-hint {
  font-size: 28rpx;
  color: #A6AAA2;
  margin-top: 12rpx;
  display: block;
}
/* ===== Module 3: Footprint Map — ProvinceMap component handles all styling ===== */
.wp-map-stat {
  text-align: center;
}
.wp-map-stat-num {
  font-size: 44rpx;
  font-weight: 500;
  color: #18231E;
  display: block;
}
.wp-map-stat-label {
  font-size: 24rpx;
  color: #7A8178;
  display: block;
  margin-top: 6rpx;
}
