@charset "UTF-8";
.cert-page {
  min-height: 100vh;
  background: #F9F6F0;
  padding-bottom: 80rpx;
}
.cert-loading {
  min-height: 100vh;
  background: #F9F6F0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.cert-loading-text {
  font-size: 30rpx;
  color: #A09B8E;
}
.cert-error {
  min-height: 100vh;
  background: #F9F6F0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}
.cert-error-text {
  font-size: 30rpx;
  color: #A09B8E;
  margin-bottom: 28rpx;
}
.cert-error-back {
  padding: 16rpx 44rpx;
  border-radius: 44rpx;
  background: #2C3328;
}
.cert-error-back-text {
  font-size: 28rpx;
  color: #F9F6F0;
}
/* ===== HERO ===== */
.cert-hero {
  width: 100%;
  height: 260rpx;
  position: relative;
  overflow: hidden;
}
.cert-hero-img {
  width: 100%;
  height: 100%;
}
.cert-hero-ph {
  width: 100%;
  height: 100%;
  background: linear-gradient(160deg, #B8A88A 0%, #8E7B5E 55%, #6B5A42 100%);
}
.cert-hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx 44rpx 32rpx;
  background: linear-gradient(180deg, transparent 0%, rgba(24, 28, 20, 0.4) 60%, rgba(24, 28, 20, 0.58) 100%);
}
.cert-hero-brand {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.65);
  letter-spacing: 8rpx;
  display: block;
  margin-bottom: 6rpx;
}
.cert-hero-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #FFF;
  line-height: 1.25;
  letter-spacing: 2rpx;
  display: block;
}
/* ===== CERTIFICATE FRAME ===== */
.cert-body {
  margin: -28rpx 28rpx 0;
  position: relative;
  z-index: 2;
}
.cert-frame {
  background: #FCFAF6;
  padding: 56rpx 40rpx 48rpx;
  text-align: center;
  outline: 2rpx solid #C8B892;
  outline-offset: -14rpx;
  position: relative;
  overflow: hidden;
}
.cert-frame::before {
  content: "";
  position: absolute;
  inset: 10rpx;
  border: 1rpx solid #C8B892;
  pointer-events: none;
}
.cert-type-en {
  font-size: 20rpx;
  color: #B0A48C;
  display: block;
  letter-spacing: 8rpx;
  margin-bottom: 8rpx;
}
.cert-type-zh {
  font-size: 34rpx;
  font-weight: 300;
  color: #2C3328;
  display: block;
  letter-spacing: 12rpx;
  margin-bottom: 24rpx;
}
.cert-divider {
  width: 48rpx;
  height: 2rpx;
  background: #C8B892;
  margin: 0 auto 28rpx;
}
.cert-act-title {
  font-size: 28rpx;
  font-weight: 400;
  color: #5A5040;
  display: block;
  margin-bottom: 36rpx;
  letter-spacing: 2rpx;
  line-height: 1.5;
}
/* ===== GRATITUDE ===== */
.cert-gratitude-label {
  font-size: 24rpx;
  color: #B0A48C;
  display: block;
  letter-spacing: 6rpx;
  margin-bottom: 10rpx;
}
.cert-gratitude-name {
  font-size: 44rpx;
  font-weight: 500;
  color: #2C3328;
  display: block;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}
.cert-gratitude-sub {
  font-size: 24rpx;
  color: #B0A48C;
  display: block;
  margin-bottom: 36rpx;
  letter-spacing: 2rpx;
}
/* ===== DETAILS ===== */
.cert-details {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-bottom: 36rpx;
}
.cert-detail-row {
  display: flex;
  justify-content: center;
  align-items: baseline;
  gap: 14rpx;
}
.cert-detail-label {
  font-size: 24rpx;
  color: #B0A48C;
  letter-spacing: 2rpx;
}
.cert-detail-value {
  font-size: 26rpx;
  color: #3E4436;
}
/* ===== QUOTE ===== */
.cert-quote {
  font-size: 26rpx;
  font-weight: 300;
  color: #6B5A42;
  display: block;
  line-height: 1.8;
  letter-spacing: 2rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}
/* ===== CERT NO ===== */
.cert-no {
  font-size: 20rpx;
  color: #C8B892;
  letter-spacing: 2rpx;
  display: block;
  margin-bottom: 20rpx;
}
/* ===== DATE ===== */
.cert-date {
  font-size: 24rpx;
  color: #A09B8E;
  display: block;
  letter-spacing: 2rpx;
}
/* ===== SEAL — bottom-right corner ===== */
.cert-seal-corner {
  position: absolute;
  bottom: 40rpx;
  right: 44rpx;
  z-index: 2;
}
.cert-seal-circle {
  width: 112rpx;
  height: 112rpx;
  border: 3rpx solid #9F5A46;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transform: rotate(-12deg);
  opacity: 0.55;
}
.cert-seal-line1 {
  font-size: 28rpx;
  color: #9F5A46;
  font-weight: 600;
  letter-spacing: 4rpx;
  line-height: 1.3;
}
.cert-seal-line2 {
  font-size: 28rpx;
  color: #9F5A46;
  font-weight: 600;
  letter-spacing: 4rpx;
  line-height: 1.3;
}
/* ===== COMPANIONS HORIZONTAL AVATAR ROW ===== */
.cert-companions {
  margin: 32rpx 36rpx 0;
}
.cert-comp-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #2C3328;
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}
.cert-comp-empty {
  font-size: 26rpx;
  color: #A09B8E;
  display: block;
  padding: 12rpx 0;
}
.cert-comp-scroll {
  width: 100%;
  white-space: nowrap;
}
.cert-comp-row {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}
.cert-comp-avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}
.cert-comp-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D9C7A3 0%, #C8B892 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cert-comp-more {
  background: #E8E3D8;
}
.cert-comp-avatar-text {
  font-size: 32rpx;
  color: #FCFAF6;
  font-weight: 600;
}
.cert-comp-more .cert-comp-avatar-text {
  font-size: 24rpx;
  color: #7A8178;
}
.cert-comp-avatar-name {
  font-size: 22rpx;
  color: #7A8178;
  max-width: 96rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
/* ===== COMPANION POPUP ===== */
.cert-popup-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: rgba(24, 35, 30, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
}
.cert-popup {
  width: 400rpx;
  background: #FCFAF6;
  border-radius: 28rpx;
  padding: 48rpx 32rpx 36rpx;
  text-align: center;
}
.cert-popup-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D9C7A3 0%, #C8B892 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
}
.cert-popup-avatar-text {
  font-size: 48rpx;
  color: #FCFAF6;
  font-weight: 600;
}
.cert-popup-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3328;
  display: block;
  margin-bottom: 8rpx;
}
.cert-popup-shared {
  font-size: 26rpx;
  color: #7A8178;
  display: block;
}
/* ===== SHARE ===== */
.cert-share-wrap {
  margin: 52rpx 48rpx 0;
}
.cert-share-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  background: #2C3328;
  border-radius: 50rpx;
}
.cert-share-text {
  font-size: 30rpx;
  font-weight: 400;
  color: #F9F6F0;
  letter-spacing: 2rpx;
}
.cert-back-link {
  margin-top: 28rpx;
  text-align: center;
}
.cert-back-link-text {
  font-size: 26rpx;
  color: #B0A48C;
}
