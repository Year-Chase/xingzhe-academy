@charset "UTF-8";
.page {
  padding: 32rpx 28rpx 60rpx;
  min-height: 100vh;
  background: #f7f8fa;
}
.loading {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 200rpx;
}
.empty {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #999;
  margin-top: 200rpx;
}
.tab-row {
  display: flex;
  gap: 12rpx;
  margin-bottom: 24rpx;
}
.tab {
  flex: 1;
  text-align: center;
  background: #fff;
  border-radius: 10rpx;
  padding: 16rpx;
  border: 1rpx solid #ebedf0;
}
.tab.active {
  border-color: #1989fa;
  background: #e8f4fd;
}
.tab-text {
  font-size: 28rpx;
  color: #333;
}
.tab.active .tab-text {
  color: #1989fa;
  font-weight: 600;
}
.review-hero {
  background: #1989fa;
  border-radius: 14rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 20rpx;
}
.review-summary {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  line-height: 1.6;
  display: block;
}
/* cards */
.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 22rpx;
  margin-bottom: 16rpx;
}
.card-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 14rpx;
}
/* 状态分布 */
.dist-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 10rpx;
}
.dist-label {
  font-size: 26rpx;
  color: #333;
  width: 150rpx;
}
.dist-bar-bg {
  flex: 1;
  height: 10rpx;
  background: #ebedf0;
  border-radius: 5rpx;
  overflow: hidden;
}
.dist-bar {
  height: 100%;
  background: #1989fa;
  border-radius: 5rpx;
}
.dist-count {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  width: 50rpx;
  text-align: right;
}
/* 压力/恢复因素 */
.factor-item {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 4rpx;
}
/* 总览 */
.stats-inline {
  display: flex;
  gap: 32rpx;
}
.stat-item {
  font-size: 26rpx;
  color: #666;
}
.bold {
  font-weight: 700;
  color: #333;
}
/* 状态分布 */
.state-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}
.state-label {
  font-size: 26rpx;
  color: #333;
  width: 160rpx;
}
.state-bar-bg {
  flex: 1;
  height: 8rpx;
  background: #ebedf0;
  border-radius: 4rpx;
  overflow: hidden;
}
.state-bar {
  height: 100%;
  background: #1989fa;
  border-radius: 4rpx;
}
.state-count {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  width: 32rpx;
  text-align: right;
}
/* 紧张度 */
.tension-row {
  display: flex;
  gap: 12rpx;
}
.t-item {
  flex: 1;
  text-align: center;
}
.t-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}
.t-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 4rpx;
}
/* 标签 */
.tag-row {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}
.tag-badge {
  flex: 1;
  text-align: center;
  border-radius: 10rpx;
  padding: 14rpx;
}
.tag-positive {
  background: #f0faf4;
}
.tag-neutral {
  background: #f0f0f0;
}
.tag-negative {
  background: #fff2f2;
}
.tag-high {
  background: #f0faf4;
}
.tag-medium {
  background: #fffbe6;
}
.tag-low {
  background: #fff2f2;
}
.badge-num {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  display: block;
}
.badge-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-top: 2rpx;
}
/* 关键片段 */
.highlight-item {
  font-size: 26rpx;
  color: #555;
  line-height: 1.6;
  display: block;
  margin-bottom: 6rpx;
}
