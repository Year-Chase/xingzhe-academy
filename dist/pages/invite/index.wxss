@charset "UTF-8";
.invite-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F2E8 0%, #FBFAF6 45%, #EEF3ED 100%);
  padding: 48rpx 32rpx 120rpx;
}
.invite-loading {
  font-size: 30rpx;
  color: #7A8178;
  text-align: center;
  margin-top: 240rpx;
  display: block;
}
/* 邀请码 hero */
.invite-hero {
  background: linear-gradient(135deg, #18231E 0%, #3F6B4F 100%);
  border-radius: 40rpx;
  padding: 56rpx 40rpx;
  text-align: center;
  margin-bottom: 32rpx;
}
.hero-label {
  font-size: 26rpx;
  color: rgba(251, 250, 246, 0.55);
  display: block;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}
.hero-code-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}
.hero-code {
  font-size: 64rpx;
  font-weight: 600;
  color: #FBFAF6;
  letter-spacing: 12rpx;
}
.copy-btn {
  font-size: 26rpx;
  color: #FBFAF6;
  padding: 6rpx 20rpx;
  background: rgba(251, 250, 246, 0.12);
  border-radius: 999rpx;
  border: 1rpx solid rgba(251, 250, 246, 0.2);
}
.hero-count {
  font-size: 28rpx;
  color: rgba(251, 250, 246, 0.55);
}
/* 邀请记录 */
.invite-section {
  background: #FBFAF6;
  border-radius: 36rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 24rpx;
}
.empty-state {
  text-align: center;
  padding: 56rpx 0;
}
.empty-text {
  font-size: 30rpx;
  color: #7A8178;
  display: block;
}
.empty-hint {
  font-size: 26rpx;
  color: #A6AAA2;
  margin-top: 12rpx;
  display: block;
}
.invite-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(24, 35, 30, 0.06);
}
.invite-item:last-child {
  border-bottom: none;
}
.item-name {
  font-size: 30rpx;
  color: #18231E;
}
.item-time {
  font-size: 26rpx;
  color: #7A8178;
}
