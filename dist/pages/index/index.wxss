@charset "UTF-8";
.activity-home {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F2E8 0%, #FBFAF6 45%, #EEF3ED 100%);
  padding: 0 32rpx 120rpx;
}
.activity-home-header {
  padding-top: 56rpx;
  padding-bottom: 32rpx;
}
.home-brand {
  margin-bottom: 20rpx;
}
.home-brand-text {
  font-size: 48rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  letter-spacing: 2rpx;
}
.home-brand-sub {
  font-size: 28rpx;
  color: #7A8178;
  display: block;
  margin-top: 8rpx;
}
/* 城市筛选 */
.city-bar {
  white-space: nowrap;
  padding: 16rpx 0 24rpx;
}
.city-tag {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 12rpx;
  border-radius: 999rpx;
  background: #FBFAF6;
  border: 1rpx solid rgba(24, 35, 30, 0.08);
}
.city-tag.active {
  background: #18231E;
  border-color: #18231E;
}
.city-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #7A8178;
}
.city-tag.active .city-text {
  color: #FBFAF6;
}
/* 加载 / 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #7A8178;
}
.empty-hint {
  font-size: 26rpx;
  color: #A6AAA2;
  margin-top: 12rpx;
}
/* 活动卡片列表 */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}
.act-card {
  background: #FBFAF6;
  border-radius: 36rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(24, 35, 30, 0.04);
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}
.act-cover {
  width: 100%;
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, #D9C7A3 0%, #E6DDCC 50%, #DCE6E2 100%);
}
.act-cover-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, #D9C7A3 0%, #E6DDCC 50%, #DCE6E2 100%);
}
.act-body {
  padding: 32rpx;
}
.act-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}
.act-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #18231E;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.3;
}
.act-city {
  padding: 4rpx 16rpx;
  border-radius: 999rpx;
  background: #F7F2E8;
  flex-shrink: 0;
}
.act-city-text {
  font-size: 24rpx;
  color: #7A8178;
}
.act-time {
  font-size: 28rpx;
  color: #7A8178;
  display: block;
  margin-bottom: 10rpx;
}
.act-summary {
  font-size: 28rpx;
  color: #7A8178;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.act-btn {
  display: inline-block;
  padding: 12rpx 28rpx;
  border-radius: 999rpx;
  background: #18231E;
  color: #FBFAF6;
  font-size: 28rpx;
  font-weight: 500;
}
/* ===== Login Bottom Sheet ===== */
.login-sheet-overlay {
  position: fixed;
  inset: 0;
  z-index: 900;
  background: rgba(24, 35, 30, 0.45);
  display: flex;
  align-items: flex-end;
}
.login-sheet {
  width: 100%;
  background: #FBFAF6;
  border-radius: 40rpx 40rpx 0 0;
  padding: 24rpx 32rpx 56rpx;
  animation: sheetUp 0.25s ease-out;
}
@keyframes sheetUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}
.login-sheet-handle {
  width: 64rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: #D9C7A3;
  margin: 0 auto 32rpx;
}
.login-sheet-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}
.login-sheet-sub {
  font-size: 28rpx;
  color: #7A8178;
  display: block;
  margin-bottom: 40rpx;
}
.login-sheet-benefits {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 40rpx;
}
.benefit-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.benefit-icon {
  font-size: 40rpx;
}
.benefit-text {
  font-size: 24rpx;
  color: #7A8178;
}
.login-sheet-phone-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 999rpx;
  background: #18231E;
  color: #FBFAF6;
  border: none;
}
.login-sheet-phone-btn::after {
  border: none;
}
.login-sheet-guest {
  margin-top: 24rpx;
  text-align: center;
  padding: 12rpx 0;
}
.guest-text {
  font-size: 28rpx;
  color: #A6AAA2;
}
