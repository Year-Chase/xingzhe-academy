@charset "UTF-8";
.pf-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F2E8 0%, #FBFAF6 45%, #EEF3ED 100%);
  padding: 56rpx 32rpx 120rpx;
}
.pf-loading {
  text-align: center;
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 240rpx;
  display: block;
}
/* 陪伴天数 hero */
.pf-hero {
  text-align: center;
  padding: 48rpx 0 56rpx;
}
.pf-days-num {
  font-size: 100rpx;
  font-weight: 200;
  color: #18231E;
  display: block;
  line-height: 1;
}
.pf-days-label {
  font-size: 28rpx;
  color: #7A8178;
  margin-top: 16rpx;
  display: block;
}
/* 分组卡片 */
.pf-section {
  background: #FBFAF6;
  border-radius: 36rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}
.pf-section-title {
  font-size: 24rpx;
  color: #A6AAA2;
  display: block;
  margin-bottom: 24rpx;
  text-transform: uppercase;
  letter-spacing: 4rpx;
}
.pf-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(24, 35, 30, 0.06);
}
.pf-row:last-child {
  border-bottom: none;
}
.pf-label {
  font-size: 30rpx;
  color: #7A8178;
}
.pf-value {
  font-size: 30rpx;
  color: #18231E;
}
.pf-value-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.copy-btn {
  font-size: 26rpx;
  color: #3F6B4F;
  padding: 6rpx 20rpx;
  background: #EEF3ED;
  border-radius: 999rpx;
}
.pf-link-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(24, 35, 30, 0.06);
}
.pf-link-row:last-child {
  border-bottom: none;
}
.pf-link-text {
  font-size: 30rpx;
  color: #18231E;
}
.pf-arrow {
  font-size: 36rpx;
  color: #D9C7A3;
}
