@charset "UTF-8";
.page {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F2E8 0%, #FBFAF6 45%, #EEF3ED 100%);
  padding: 48rpx 32rpx 120rpx;
}
.page-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #18231E;
  margin-bottom: 32rpx;
  display: block;
  letter-spacing: 1rpx;
}
.header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}
.my-link {
  font-size: 28rpx;
  color: #3F6B4F;
}
.loading {
  text-align: center;
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 200rpx;
  display: block;
}
.empty {
  text-align: center;
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 160rpx;
  display: block;
}
/* 活动卡片 */
.card {
  background: #FBFAF6;
  border-radius: 36rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(24, 35, 30, 0.04);
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}
.cover {
  width: 100%;
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, #D9C7A3 0%, #E6DDCC 50%, #DCE6E2 100%);
}
.cover-placeholder {
  width: 100%;
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, #D9C7A3 0%, #E6DDCC 50%, #DCE6E2 100%);
}
.card-body {
  padding: 32rpx;
}
.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #18231E;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.tag {
  font-size: 24rpx;
  font-weight: 500;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
}
.tag-PUBLISHED {
  background: #EEF3ED;
  color: #3F6B4F;
}
.tag-FINISHED {
  background: #F7F2E8;
  color: #7A8178;
}
.tag-CANCELLED {
  background: #FDF3EF;
  color: #B35B4B;
}
.meta {
  font-size: 28rpx;
  color: #7A8178;
  display: block;
}
.price {
  font-size: 30rpx;
  color: #B35B4B;
  font-weight: 600;
  margin-top: 10rpx;
  display: block;
}
