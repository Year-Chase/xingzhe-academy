@charset "UTF-8";
.page {
  min-height: 100vh;
  background: #F7F2E8;
  padding-bottom: 160rpx;
}
.loading {
  text-align: center;
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 240rpx;
  display: block;
}
.empty {
  text-align: center;
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 240rpx;
  display: block;
}
/* 封面 */
.hero-img {
  width: 100%;
  aspect-ratio: 16/9;
  background: linear-gradient(135deg, #D9C7A3 0%, #E6DDCC 60%, #DCE6E2 100%);
}
/* 内容区 */
.section {
  background: #FBFAF6;
  padding: 40rpx 32rpx;
  margin: 0 32rpx 24rpx;
  border-radius: 36rpx;
  border: 1rpx solid rgba(24, 35, 30, 0.06);
}
.section:first-of-type {
  margin-top: -48rpx;
  position: relative;
  z-index: 1;
}
.title {
  font-size: 44rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  line-height: 1.3;
}
.summary {
  font-size: 30rpx;
  color: #7A8178;
  margin-top: 16rpx;
  line-height: 1.7;
  display: block;
}
/* 信息 grid */
.info-item {
  display: flex;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(24, 35, 30, 0.06);
}
.info-item:last-child {
  border-bottom: none;
}
.info-label {
  font-size: 28rpx;
  color: #7A8178;
  width: 96rpx;
  flex-shrink: 0;
}
.info-value {
  font-size: 28rpx;
  color: #18231E;
}
/* 活动介绍 */
.section-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #18231E;
  display: block;
  margin-bottom: 16rpx;
}
.content {
  font-size: 30rpx;
  color: #3E463F;
  line-height: 1.8;
}
/* 底部操作区 */
.bottom {
  text-align: center;
  padding: 40rpx 32rpx;
}
.notice-text {
  font-size: 28rpx;
  color: #7A8178;
}
.register-btn {
  display: inline-block;
  width: 100%;
  max-width: 480rpx;
  height: 96rpx;
  line-height: 96rpx;
  font-size: 32rpx;
  font-weight: 500;
  color: #FBFAF6;
  background: #18231E;
  border-radius: 999rpx;
  text-align: center;
}
.pay-btn {
  background: #3F6B4F;
}
.reg-status {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.registered-tag {
  font-size: 30rpx;
  color: #4F7A5A;
  font-weight: 600;
}
.registered-tag.disabled {
  color: #7A8178;
}
.cancel-link {
  font-size: 26rpx;
  color: #B35B4B;
  text-decoration: underline;
}
.share-row {
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(24, 35, 30, 0.06);
  text-align: center;
}
.share-text {
  font-size: 30rpx;
  color: #3F6B4F;
}
